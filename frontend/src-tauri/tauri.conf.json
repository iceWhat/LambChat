{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LambChat",
  "version": "2.5.0",
  "identifier": "com.lambchat.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm packaged:build"
  },
  "app": {
    "windows": [
      {
        "title": "LambChat",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "T8eGmTNDhF6TuPOvREjRqYgJ/VDHn96kWVGm8Q+1+Bo=",
      "endpoints": [
        "https://github.com/Yanyutin753/LambChat/releases/latest/download/latest.json"
      ]
    }
  }
}
